# Example API key file. COPY THIS FILE TO .env (or fill your real config like
# ~/.hermes/.env) and add your actual tokens. NEVER commit real keys.
#
# All three forms below are equivalent for any one provider — hermes-router
# accepts the singular, plural, or numbered form for env_key values:
#
#   ZAI_API_KEY=k1
#   ZAI_API_KEYS=k1,k2,k3
#   ZAI_API_KEY_2=k2
#
# Pick the one you prefer.

# ── FREE pool ─────────────────────────────────────────────────────────────────

# Z.AI / Zhipu GLM (Coding Plan subscription, prepaid until 2027-01)
GLM_API_KEY=

# Kilo Code (month-to-month prepaid)
KILOCODE_API_KEY=

# MiniMax (prepaid through 2027-06)
MINIMAX_API_KEY=

# GitHub Models (free tier for personal accounts)
# Note: uses GITHUB_TOKEN (your existing GitHub PAT)
GITHUB_TOKEN=

# Google Gemini free tier
GEMINI_API_KEY=

# ── PAID pool ─────────────────────────────────────────────────────────────────

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter — can host either free (":free" models in config.yaml) or paid models
OPENROUTER_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=

# Venice AI (prepaid credits)
VENICE_API_KEY=
